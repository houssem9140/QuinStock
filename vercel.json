{
  "version": 2,
  "builds": [
    {
      "src": "Backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "Backend/api/index.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "Frontend/static/$1"
    },
    {
      "src": "/products/(.*)",
      "dest": "Frontend/products/$1"
    },
    {
      "src": "/categories/(.*)",
      "dest": "Frontend/categories/$1"
    },
    {
      "src": "/(.*\\.(?:ico|svg|png|jpg|jpeg|webp|json|txt|xml|webmanifest))",
      "dest": "Frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Frontend/index.html"
    }
  ]
}
